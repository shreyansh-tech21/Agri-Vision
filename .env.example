# Copy this file to `.env` and fill in the values below.
# NOTE: `SECRET_KEY` is required in production and the app will refuse to start if missing.
# Generate a secure key like this:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Get your free API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key

# Redis configuration (defaults to localhost:6379 for local dev)
# In Docker Compose, set REDIS_HOST=redis (the service name)
# For cloud managed Redis, set to your provider's endpoint
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Google OAuth 2.0 (issue #626)
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
